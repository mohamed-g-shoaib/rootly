{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "sortImports": {
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "value-internal",
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  },
  "sortTailwindcss": {
    "functions": ["clsx", "cn", "cva"]
  },
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": ["oldproject/**"]
}
